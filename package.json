{
  "name": "polydesk-mcp",
  "version": "1.0.0",
  "description": "PolyDesk — Polymarket AI Research & Trading Control Plane. Auto-research prediction markets, manage trades via Notion dashboard. Works alongside the official Notion MCP server.",
  "type": "module",
  "private": true,
  "bin": {
    "polydesk-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "mcp",
    "notion",
    "polymarket",
    "prediction-markets",
    "trading",
    "auto-research",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@notionhq/notion-mcp-server": "^2.2.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
